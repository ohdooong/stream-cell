<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.streamcell.web.user.repository.UserRepository">

    <select id="findAll" resultType="com.streamcell.web.user.domain.User">
        SELECT
            user_id,
            email,
            password,
            name,
            status
        FROM web.users
    </select>

    <select id="findExistingUserIds" resultType="Long">
        select
            user_id
        from web.users
        where user_id in
        <foreach collection="userIds" item="userId" open="(" close=")" separator=",">
            #{userId}
        </foreach>
    </select>

</mapper>
